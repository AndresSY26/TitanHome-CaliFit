<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/header') %>
</head>
<body>

    <!-- Navegación -->
    <nav>
        <div class="container nav-content">
            <div class="logo">
                <i class="fa-solid fa-dumbbell"></i>
                <span class="logo-text">TitanHome <span>CaliFit</span></span>
            </div>
            <div class="nav-right">
                <span class="nav-slogan">Forja tu cuerpo sin excusas</span>
                <button class="btn btn-ghost btn-sm" onclick="showSection('guild-section')" style="margin-right: 0.5rem; color: var(--text-secondary);">
                    <i class="fa-solid fa-users-rays"></i> Gremio
                </button>
                <button class="btn btn-primary btn-sm" onclick="openProfileModal()">
                    <i class="fa-solid fa-bolt"></i> <span id="nav-btn-text">Mi Plan</span>
                </button>
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <header id="hero-section">
        <div class="hero-bg"></div>
        <div class="hero-gradient"></div>
        <div class="hero-content">
            <h1>Tu Gimnasio es <span class="text-accent">Tu Cuerpo</span></h1>
            <p>Ejercicios basados en peso corporal para desarrollar fuerza extrema e hipertrofia desde casa.</p>
            <button class="btn btn-primary btn-lg" onclick="openProfileModal()">Comenzar y Crear mi Rutina</button>
        </div>
    </header>

    <!-- Contenido Principal -->
    <main class="container main-content">
        <%- include('partials/dashboard') %>
        <%- include('partials/catalog') %>
        <%- include('partials/guild') %>

        <div id="loading-state" class="state-msg hidden">
            <div class="loader"></div>
            <p>Conectando a la API y cargando base de datos...</p>
        </div>
        <div id="error-state" class="state-msg hidden">
            <i class="fa-solid fa-triangle-exclamation" style="color:var(--red); font-size:3rem; margin-bottom:1rem;"></i>
            <h3>Error de conexión</h3>
            <p>No se pudo cargar la base de datos de ejercicios.</p>
            <button onclick="loadExercises()" class="btn btn-primary" style="margin-top:1rem;">Reintentar</button>
        </div>
        <div id="no-results" class="state-msg hidden">
            <i class="fa-solid fa-ghost" style="color:var(--text-secondary); font-size:4rem; margin-bottom:1rem;"></i>
            <h3 style="color:var(--text-secondary);">No se encontraron ejercicios</h3>
        </div>
    </main>

    <%- include('partials/modals') %>
    <%- include('partials/footer') %>

    <script src="/js/app.js"></script>
</body>
</html>
