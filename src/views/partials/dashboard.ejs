<!-- DASHBOARD DE ENTRENAMIENTO -->
<div id="main-dashboard" class="dashboard hidden">
    <div class="dashboard-glow"></div>

    <div class="dashboard-header">
        <h2 class="dashboard-title">Tu Camino del Titán</h2>

        <div class="badge-container">
            <span class="badge">Nivel: <strong id="dash-level">--</strong></span>
            <span class="badge">IMC: <strong id="dash-imc">0</strong></span>
            <span class="badge">Duración: <strong id="dash-duration">0 min</strong></span>
            <span class="badge">Formato: <strong id="dash-reps">0</strong></span>
            <span class="badge">Frecuencia: <strong id="dash-freq">0 Días</strong></span>
        </div>

        <div class="gamification-widget">
            <div class="gamification-header">
                <div class="gamification-icon-wrap">
                    <i class="fa-solid fa-khanda gamification-icon"></i>
                </div>
                <div class="gamification-rank-info">
                    <span class="rank-label">Rango del Titán</span>
                    <h2 id="dash-rank" class="rank-name">Cazador Rango E</h2>
                </div>
            </div>
            <div class="exp-container">
                <div class="exp-bar-bg">
                    <div id="exp-fill" class="exp-bar-fill"></div>
                </div>
                <p id="exp-text" class="exp-text">Repeticiones Totales: 0 / 500 para el siguiente Rango</p>
            </div>
        </div>

        <div class="weekly-section">
            <h3 class="section-title section-title--blue">Distribución Semanal <span class="section-subtitle">(Qué días entrenar y cuáles descansar)</span></h3>
            <div id="weekly-calendar" class="calendar"></div>
        </div>
    </div>

    <!-- Time Tracker -->
    <div id="time-tracker" class="time-tracker time-tracker--idle">
        <div class="time-tracker__info">
            <i class="fa-regular fa-clock time-tracker__icon"></i>
            <div>
                <p class="time-tracker__label">Rastreador de Horario</p>
                <p class="time-tracker__status" id="tracker-status">Calculando...</p>
            </div>
        </div>
        <div class="time-tracker__time">
            <p class="time-tracker__label">Hora Programada:</p>
            <p class="time-tracker__clock" id="tracker-scheduled-time">00:00</p>
        </div>
    </div>

    <div class="coach-tip-widget" style="background: rgba(30, 41, 59, 0.8); border-left: 4px solid var(--accent); padding: 1.5rem; border-radius: 1rem; margin-bottom: 2rem; backdrop-filter: blur(8px);">
        <h4 style="color: var(--accent); margin-bottom: 0.5rem; font-family: 'Oswald'; text-transform: uppercase;"><i class="fa-solid fa-apple-whole"></i> Consejo Táctico del Coach</h4>
        <p id="dash-coach-tip" style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6; font-family: 'Roboto', sans-serif;">Calculando macronutrientes estratégicos...</p>
    </div>

    <h3 class="section-title section-title--yellow">Misión Diaria <i class="fa-solid fa-scroll"></i> <span class="section-subtitle">(Haz clic en los ejercicios para ver cómo hacerlos)</span></h3>

    <div class="routine-grid" id="routine-days"></div>

    <div class="stats-container" style="max-width: 400px; margin: 3rem auto; background: rgba(30, 41, 59, 0.65); backdrop-filter: blur(12px); border: 1px solid rgba(234,179,8,0.3); border-radius: 1.5rem; padding: 1.5rem; box-shadow: 0 0 20px rgba(234,179,8,0.1);">
        <h3 style="text-align:center; color: var(--accent); font-family: 'Oswald'; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.1em;">Estado del Cazador</h3>
        <canvas id="rpgStatsChart"></canvas>
    </div>
</div>
