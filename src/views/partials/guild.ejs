<section id="guild-section" class="hidden" style="margin-top: 2rem;">
    <div class="guild-container" style="background: rgba(30, 41, 59, 0.65); backdrop-filter: blur(12px); border: 1px solid rgba(234,179,8,0.3); border-radius: 1.5rem; padding: 2rem; box-shadow: 0 0 20px rgba(234,179,8,0.1);">
        <h2 style="text-align:center; color: var(--accent); font-family: 'Oswald'; margin-bottom: 2rem; text-transform: uppercase; letter-spacing: 0.1em;">El Gremio de Cazadores <span style="color: var(--text-secondary);">[Top 10]</span></h2>
        
        <div class="table-responsive">
            <table class="guild-table" style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="border-bottom: 2px solid rgba(255,255,255,0.1); color: var(--text-secondary); font-family: 'Oswald'; text-transform: uppercase; font-size: 0.9rem;">
                        <th style="padding: 1rem;">#</th>
                        <th style="padding: 1rem;">Cazador</th>
                        <th style="padding: 1rem; text-align: right;">Poder Total</th>
                    </tr>
                </thead>
                <tbody id="guild-tbody">
                    <!-- Se generará dinámicamente -->
                </tbody>
            </table>
        </div>
    </div>
</section>
